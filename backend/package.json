{
  "name": "hirebit-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node -r newrelic dist/server.js",
    "migrate": "node-pg-migrate",
    "db:schema": "npm run migrate up",
    "check": "tsx scripts/check-env.ts",
    "ensure-admin": "tsx scripts/ensure-admin-user.ts",
    "test:verification-email": "tsx scripts/send-test-verification-code.ts",
    "test:talent-pool": "tsx scripts/test-talent-pool-notification.ts",
    "seed:talent-pool-fake": "tsx scripts/seed-talent-pool-fake-data.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@types/ioredis": "^4.28.10",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csrf": "^3.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "groq-sdk": "^0.37.0",
    "imapflow": "^1.1.1",
    "ioredis": "^5.9.2",
    "ioredis-mock": "^8.13.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.0",
    "mammoth": "^1.11.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "newrelic": "^14.0.0",
    "nodemailer": "^7.0.10",
    "pdfkit": "^0.17.2",
    "pg": "^8.21.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "react-hot-toast": "^2.6.0",
    "resend": "^6.6.0",
    "unpdf": "^0.6.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "node-pg-migrate": "^8.0.4",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
