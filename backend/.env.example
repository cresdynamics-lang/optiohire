DB_SSL=true
# ============================================================================
# ============================================================================
# ============================================================================
# ============================================================================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=your_jwt_secret_key_change_this_in_production
# ============================================================================
# ============================================================================
# ============================================================================
# ============================================================================
# Send candidate emails (shortlist/rejection) and fallback from address
MAIL_FROM=applicationsoptiohire@gmail.com
RESEND_FROM_EMAIL=applicationsoptiohire@gmail.com
RESEND_FROM_NAME=OptioHire
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=applicationsoptiohire@gmail.com
SMTP_PASS=your_app_specific_password
# ============================================================================
# ============================================================================
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=applicationsoptiohire@gmail.com
IMAP_PASS=your_app_specific_password
IMAP_SECURE=true
IMAP_POLL_MS=30000
ENABLE_EMAIL_READER=false
# ============================================================================
# ============================================================================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEY_002=your_gemini_api_key_002
GEMINI_API_KEY_003=your_gemini_api_key_003
REPORT_AI_MODEL=gemini-1.5-flash
SCORING_MODEL=gemini-1.5-flash
RESUME_PARSER_MODEL=gemini-1.5-flash
# ============================================================================
# ============================================================================
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/company-details
N8N_INCOMING_WEBHOOK_URL=https://your-n8n-instance.com/webhook/incoming-data
PUBLIC_API_BASE_URL=http://localhost:3001
# ============================================================================
# ============================================================================
CRON_SECRET=your_cron_secret_key_here
# ============================================================================
# ============================================================================
DISABLE_REPORT_SCHEDULER=false
# ============================================================================
# ============================================================================
S3_BUCKET=resumes
S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-secret-access-key
S3_ENDPOINT=https://[PROJECT_REF].storage.supabase.co/storage/v1/s3
S3_REGION=us-east-1
S3_BUCKET_URL=https://[PROJECT_REF].storage.supabase.co/storage/v1/object/public/resumes
PDF_BUCKET_URL=https://[PROJECT_REF].storage.supabase.co/storage/v1/object/public/resumes
PDF_BUCKET_KEY=your-bucket-key

Optiohire.com backend environment variables
# =======================================================================
# COMPLETE ENVIRONMENT VARIABLES - OptioHire Backend
# =======================================================================
# Copy/adapt from this file as needed. Replace placeholders with actual values.
# =======================================================================

# =======================================================================
# PostgreSQL Database Configuration (REQUIRED)
# =======================================================================
DATABASE_URL=postgresql://optiohire_user:optiohire_pass_2024@localhost:5432/optiohire
DB_SSL=false
DATABASE_URL_POOLER=your_pooler_connection_string
DATABASE_URL_DIRECT=your_direct_connection_string

# =======================================================================
# Backend Server Configuration
# =======================================================================
PORT=3001
NODE_ENV=production
JWT_SECRET=optiohire_jwt_secret_change_in_production_2024

# =======================================================================
# Frontend Configuration
# =======================================================================
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# =======================================================================
# Google SSO / OAuth Configuration
# =======================================================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# =======================================================================
# Email Configuration - Priority: Resend > SendGrid > SMTP
# =======================================================================
USE_RESEND=true
RESEND_API_KEY=your_resend_api_key_here
RESEND_API_KEY_SECONDARY=your_resend_api_key_secondary_here
RESEND_API_KEY_FALLBACK=your_resend_api_key_fallback_here
RESEND_DOMAIN=optiohire.com
RESEND_FROM_EMAIL=noreply@optiohire.com
RESEND_FROM_NAME=OptioHire
USE_SENDGRID=false
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@optiohire.com
SENDGRID_FROM_NAME=OptioHire
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=applicationsoptiohire@gmail.com
SMTP_PASS=your_smtp_app_password_here
MAIL_HOST=smtp.gmail.com
MAIL_USER=applicationsoptiohire@gmail.com
MAIL_PASS=your_mail_password_here
MAIL_PORT=587

# =======================================================================
# IMAP Configuration (Email Reading)
# =======================================================================
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=applicationsoptiohire@gmail.com
IMAP_PASS=your_imap_password_here
IMAP_SECURE=true
IMAP_POLL_MS=5000
ENABLE_EMAIL_READER=true

# =======================================================================
# AI Configuration - Using Groq (AI_PROVIDER=groq)
# =======================================================================
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_002=your_groq_api_key_2_here
GROQ_API_KEY_003=your_groq_api_key_3_here
GROQ_MODEL=llama-3.1-8b-instant
SCORING_MODEL=llama-3.1-8b-instant
REPORT_AI_MODEL=llama-3.1-8b-instant
RESUME_PARSER_MODEL=llama-3.1-8b-instant
CV_EXTRACTION_MODEL=llama-3.1-8b-instant
AI_CV_ANALYSIS_ENABLED=true
AI_CV_CONFIDENCE_THRESHOLD=0.7
AI_CV_MAX_FILE_SIZE=10485760
AI_CV_SUPPORTED_FORMATS=pdf,doc,docx,txt
CV_SKILLS_EXTRACTION_ENABLED=true

# =======================================================================
# Job Posting APIs
# =======================================================================
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
INDEED_PUBLISHER_ID=your_indeed_publisher_id
INDEED_API_KEY=your_indeed_api_key
GLASSDOOR_PARTNER_ID=your_glassdoor_partner_id
GLASSDOOR_KEY=your_glassdoor_key

# =======================================================================
# CV Cron Watch & Processing
# =======================================================================
CV_WATCH_ENABLED=true
CV_WATCH_INTERVAL=300000
CV_PROCESSING_BATCH_SIZE=10
CV_WATCH_DIRECTORIES=./uploads/cvs,./storage/resumes

# =======================================================================
# Activation APIs
# =======================================================================
ACTIVATION_EMAIL_TEMPLATE_ID=your_activation_template_id
AUTO_ACTIVATION_ENABLED=true
ACTIVATION_WEBHOOK_URL=https://your-webhook.com/activation
USER_ACTIVATION_TOKEN_SECRET=your_activation_token_secret

# =======================================================================
# Email Automation (Rejected & Shortlisted Candidates)
# =======================================================================
REJECTION_EMAIL_TEMPLATE_ID=template_rejection
SHORTLIST_EMAIL_TEMPLATE_ID=template_shortlist
AUTO_EMAIL_REJECTION=true
AUTO_EMAIL_SHORTLIST=true
HR_NOTIFICATION_EMAIL=hr@company.com
CANDIDATE_UPDATE_WEBHOOK=https://your-webhook.com/candidate-updates

# =======================================================================
# HR Notifications & Updates
# =======================================================================
HR_NOTIFICATION_WEBHOOK=https://your-n8n-instance.com/webhook/hr-notifications
HR_EMAIL_NOTIFICATIONS=true
HR_SLACK_WEBHOOK=https://hooks.slack.com/services/your/slack/webhook
HR_UPDATE_FREQUENCY=3600000
NEW_APPLICATION_ALERTS=true

# =======================================================================
# Webhook Configuration (N8N)
# =======================================================================
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/company-details
N8N_INCOMING_WEBHOOK_URL=https://your-n8n-instance.com/webhook/incoming-data
PUBLIC_API_BASE_URL=http://localhost:3001

# =======================================================================
# Cron/Security Configuration
# =======================================================================
CRON_SECRET=optiohire_cron_a1b2c3d4e5f6789012345678abcdef0123456789abcdef01234567
DISABLE_REPORT_SCHEDULER=false

# =======================================================================
# Admin Configuration
# =======================================================================
ADMIN_EMAIL=admin@optiohire.com
ADMIN_PASSWORD=OptioHire@Admin
ADMIN_SECRET_TOKEN=02ef4c65b64cd3fc60773a0e2ada8183540a3858745182af7662147f539fd9d3
ADMIN_EMAILS=admin@optiohire.com

# =======================================================================
# Storage Configuration (S3 Compatible)
# =======================================================================
S3_BUCKET=resumes
S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-secret-access-key
S3_ENDPOINT=https://your-s3-endpoint.com
S3_REGION=us-east-1
S3_BUCKET_URL=https://your-s3-bucket-url.com/resumes
PDF_BUCKET_URL=https://your-s3-bucket-url.com/resumes
PDF_BUCKET_KEY=your-bucket-key
FILE_STORAGE_DIR=./storage

# =======================================================================
# Performance & Monitoring
# =======================================================================
ENABLE_PERFORMANCE_MONITORING=true
LOG_LEVEL=info
METRICS_WEBHOOK=https://your-monitoring.com/webhook

# =======================================================================
# Deployment & Environment Control
# =======================================================================
ENV_FILE=./backend/.env

# =======================================================================
# Redis Cache Configuration (Optional)
# =======================================================================
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =======================================================================
# AI Batch Processing Configuration
# =======================================================================
AI_BATCH_SIZE=5
AI_BATCH_DELAY_MS=1000

# =======================================================================
# Database Pool Configuration
# =======================================================================
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=10000
DB_STATEMENT_TIMEOUT=30000
 
 
 Frontend Environment variables
 
