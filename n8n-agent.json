          "sendBody": true,
          "bodyContent": "={ \"from\": \"OptioHire <system@optiohire.com>\", \"to\": \"{{ $node[\\\"Reader\\\"].json.hr_email }}\", \"subject\": \"Manual Review Needed\", \"html\": \"Candidate {{ $node[\\\"Reader\\\"].json.candidate_name }} needs review.\" }"
        },
        "id": "mail-flag",
        "name": "Flag",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.1,
        "position": [1800, 500]
      },
      {
        "parameters": {
          "operation": "update",
          "table": "applications",
          "where": "application_id = {{ $node[\"Reader\"].json.application_id }}",
          "values": {
            "ai_score": "={{ $node[\"Judge\"].json.final_score }}",
            "ai_status": "={{ $node[\"Judge\"].json.bucket === 'REJECT' ? 'REJECT' : 'SHORTLIST' }}",
            "reasoning": "={{ $node[\"Judge\"].json.reasoning }}"
          }
        },
        "id": "db-sync",
        "name": "Sync",
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2,
        "position": [2100, 400]
      }
