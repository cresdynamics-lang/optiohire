{
  "name": "hirebit-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "check": "cd backend && npm run check",
    "build": "cd frontend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "cd frontend && npm run start",
    "lint": "cd frontend && npm run lint",
    "install:all": "cd frontend && npm install && cd ../backend && npm install",
    "db:schema": "cd backend && npm run db:schema",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && npm install"
  },
  "description": "HireBit Recruitment System - Monorepo",
  "workspaces": [],
  "dependencies": {
    "groq-sdk": "^0.37.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
